# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# GitHub API 配置
# ============================================================================
GH_TOKEN=ghp_xxxxxxxxxxxxx
TOPIC=claude-code

# ============================================================================
# 模型网关配置（LiteLLM）
# ============================================================================
# 命名参考: https://docs.litellm.ai/docs/providers
# 示例: ollama/gemma3:4b, openai/gpt-4o-mini, moonshot/moonshot-v1-8k
MODEL="ollama/gemma3:4b"
# API Key 请在系统环境变量中配置（例如 OPENAI_API_KEY / MOONSHOT_API_KEY）
LLM_MAX_TOKENS=8192

# ============================================================================
# Resend 邮件服务配置
# ============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
# 支持多个收件人，使用英文逗号分隔
# 示例: EMAIL_TO=alice@example.com,bob@example.com
EMAIL_TO=your-email@example.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# 数据库配置
# ============================================================================
# sqlite / postgres（默认 sqlite）
DB_BACKEND=sqlite
DB_PATH=data/github-trending.db

# PostgreSQL 配置（当 DB_BACKEND=postgres 时生效）
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=github_trend_analysis
PG_USER=gh_analyzer
PG_PASSWORD=dev123dev321
PG_SSLMODE=prefer
# 可选：完整 DSN，若提供则优先于 PG_* 配置
# DATABASE_URL=postgresql://gh_analyzer:dev123dev321@localhost:5432/github_trend_analysis?sslmode=prefer

DB_RETENTION_DAYS=90

# ============================================================================
# GitHub 抓取缓存配置
# ============================================================================
GITHUB_CACHE_MINUTES=30

# ============================================================================
# 模型请求频率控制
# ============================================================================
MODEL_MAX_CONCURRENCY=4
MODEL_MAX_RPM=80
# JSON 解析失败后的自动修复重试次数（0=关闭，建议 1）
LLM_JSON_REPAIR_RETRIES=1

# AI 分析数量上限（debug 时可设为 2 降低开销）
TOP_N_DETAILS=50

# ============================================================================
# 关键词检索 + 自定义分析 Prompt（配置文件驱动）
# ============================================================================
# 示例: ANALYSIS_KEYWORDS=agent,workflow,mcp,automation
ANALYSIS_KEYWORDS=
# 可选: any（命中任意关键词） / all（必须命中全部关键词）
ANALYSIS_KEYWORD_MATCH_MODE=any
# 多行建议使用 \n
ANALYSIS_CUSTOM_PROMPT=

# 邮件推送最低商业价值阈值：strong（仅强）/ weak（强+弱）
PUSH_MIN_COMMERCIAL_LEVEL=strong

# ============================================================================
# 全链路 429 冷却重试配置
# ============================================================================
HTTP_429_COOLDOWN_SECONDS=60
HTTP_429_MAX_RETRIES=3

# ============================================================================
# 告警阈值（星标暴涨检测，0.3 = 30%）
# ============================================================================
SURGE_THRESHOLD=0.3

# ============================================================================
# GitHub Pages 配置（可选）
# ============================================================================
OUTPUT_DIR=docs
GITHUB_PAGES_URL=https://username.github.io/github-topics-trending
